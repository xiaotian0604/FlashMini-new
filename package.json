{
  "name": "flashmini",
  "version": "1.0.0",
  "description": "多平台小程序一键上传 CLI 工具，支持微信/支付宝/百度/字节小程序",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "flashmini": "./bin/flashmini.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./plugins/*": {
      "import": "./dist/plugins/*.js",
      "require": "./dist/plugins/*.cjs",
      "types": "./dist/plugins/*.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "templates"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "node ./scripts/check-node-version.mjs && tsup --watch",
    "build": "node ./scripts/check-node-version.mjs && tsup",
    "test": "node ./scripts/check-node-version.mjs && vitest run",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "miniprogram",
    "wechat",
    "alipay",
    "baidu",
    "bytedance",
    "upload",
    "cli",
    "ci-cd"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "ora": "^8.1.0",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
